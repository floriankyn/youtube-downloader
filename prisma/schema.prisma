generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  favorites    Favorite[]
  notes        Note[]
}

model Note {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  blocks         Json     @default("[]")
  timecodes      Json     @default("[]")
  songName       String?
  isPublic       Boolean  @default(false)
  publicId       String?  @unique
  bpm            String?
  key            String?
  beatType       String?
  videoTitle     String?
  videoThumbnail String?
  videoUrl       String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  videoId     String
  title       String
  thumbnail   String
  duration    String
  durationSec Int
  url         String
  bpm         String?
  key         String?
  beatType    String?
  inspiredBy   String[]
  tags         String[]
  dateFilter   String?
  freeFilter   Boolean  @default(false)
  artistFilter String?
  typeBeat     Boolean  @default(false)
  createdAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}
